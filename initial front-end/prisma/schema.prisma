generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  profile      StudentProfile?
  progress     ProgressEntry[]
  achievements Achievement[]
  goals        Goal[]
}

model StudentProfile {
  id        String @id @default(cuid())
  userId    String @unique
  fullName  String
  yearLevel String
  course    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SRAColorLevel {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  hexColor    String
  order       Int             @unique
  gradeLevel  String
  lexileRange String?
  progress    ProgressEntry[] @relation("CurrentLevel")
  targetProgress ProgressEntry[] @relation("TargetLevel")
  currentGoals   Goal[]       @relation("CurrentGoalLevel")
  targetGoals    Goal[]       @relation("TargetGoalLevel")
}

model ProgressEntry {
  id                    String        @id @default(cuid())
  userId                String
  colorLevelId          String
  targetColorLevelId    String?
  date                  DateTime      @default(now())
  powerBuildersCompleted Int
  score                 Int
  totalItems            Int           @default(20)
  timeframe             String        @default("daily")
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  colorLevel            SRAColorLevel @relation("CurrentLevel", fields: [colorLevelId], references: [id])
  targetColorLevel      SRAColorLevel? @relation("TargetLevel", fields: [targetColorLevelId], references: [id])
}

model Goal {
  id                  String        @id @default(cuid())
  userId              String
  currentColorLevelId String
  targetColorLevelId  String
  timeframe           String        @default("monthly")
  targetDate          DateTime?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLevel        SRAColorLevel @relation("CurrentGoalLevel", fields: [currentColorLevelId], references: [id])
  targetLevel         SRAColorLevel @relation("TargetGoalLevel", fields: [targetColorLevelId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  earnedAt    DateTime @default(now())
  metadata    String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model GradingRubric {
  id             String @id @default(cuid())
  levelName      String @unique
  minScore       Int
  maxScore       Int
  description    String
  interpretation String
  order          Int    @unique
}
